---
const problems = [
  {
    pain: "I thought dating was a huge deal and never made a move",
    quote: "I originally thought dating was a serious step and didn't want to make a move too fast... I made a serious mistake of never asking her out on a date, but on Valentine's Day giving her a box of chocolates with a letter telling her that I loved her.",
    source: "Reddit post with 4,160 upvotes",
    solution: "Module 1 teaches the actual psychology of modern dating—what a date actually is, when to ask, how escalation works, and why \"confessing love\" too early destroys chances."
  },
  {
    pain: "I want to puke on the thought of sitting with someone I don't know face to face and talking.",
    quote: "I'm the most shy, introverted, socially awkward guy ever... Women always show interest but after they realized I can't communicate properly they lose it.",
    source: "Reddit post with 3,675 upvotes",
    solution: "Module 2 breaks down conversation skills specifically for introverts—how to listen deeply, when to speak, and how to use your natural thoughtfulness as an asset."
  },
  {
    pain: "I'm constantly learning what I lack, and how I'm not good enough for people.",
    quote: "I've been either told I'm too boring, or too quiet by a few women so far... I don't feel good enough for a long time. I questioned my worth.",
    source: "Reddit post with 1,669 upvotes",
    solution: "Module 3 rebuilds confidence from the inside out—not fake bravado, but quiet certainty in your actual value."
  }
];
---
<section class="py-16 sm:py-24 px-4">
  <div class="max-w-4xl mx-auto">
    <h2 class="font-heading text-3xl sm:text-4xl font-bold text-primary text-center mb-12 sm:mb-16">
      We Get It. We've Been There.
    </h2>
    
    <div class="space-y-12 sm:space-y-16">
      {problems.map((item, index) => (
        <div class="bg-white rounded-xl p-6 sm:p-8 border border-gray-100 shadow-sm">
          <div class="flex flex-col gap-6">
            <div>
              <h3 class="font-heading text-xl sm:text-2xl font-semibold text-primary mb-4">
                "{item.pain}"
              </h3>
              <blockquote class="border-l-4 border-accent/40 pl-4 italic text-text-muted mb-4">
                "{item.quote}"
              </blockquote>
              <p class="text-xs text-gray-400">
                — {item.source}
              </p>
            </div>
            
            <div class="bg-surface rounded-lg p-5">
              <span class="text-xs font-semibold text-accent uppercase tracking-wide">Solution</span>
              <p class="text-text-main mt-2">
                {item.solution}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
