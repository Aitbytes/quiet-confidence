---
const steps = [
  {
    step: "Learn the Framework",
    outcome: "You understand the actual \"rules\" of dating that nobody ever taught you—when to ask someone out, what a date is really for, how escalation works."
  },
  {
    step: "Practice Conversation Skills",
    outcome: "You can hold comfortable conversations without anxiety, using techniques designed for how introverts process and respond."
  },
  {
    step: "Build Quiet Confidence",
    outcome: "You date as yourself—not a performance. You attract people who actually fit your personality type."
  }
];
---
<section id="how-it-works" class="py-16 sm:py-24 px-4 bg-white">
  <div class="max-w-6xl mx-auto">
    <h2 class="font-heading text-3xl sm:text-4xl font-bold text-primary text-center mb-12 sm:mb-16">
      How It Works
    </h2>
    
    <div class="grid sm:grid-cols-3 gap-8 sm:gap-12">
      {steps.map((item, index) => (
        <div class="text-center">
          <div class="w-16 h-16 bg-accent/10 rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="text-2xl font-bold text-accent">{index + 1}</span>
          </div>
          <h3 class="font-heading text-xl font-semibold text-primary mb-3">
            {item.step}
          </h3>
          <div class="w-12 h-0.5 bg-accent mx-auto mb-4"></div>
          <p class="text-text-muted leading-relaxed">
            {item.outcome}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
